  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7F848E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": ["string"],
      "settings": {
        "foreground": "#89B86A"
      }
    },
    {
      "name": "Number, Constant",
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#D19A66"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#E06C75",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Keyword, Storage Modifier",
      "scope": ["keyword", "storage.modifier", "variable.language.this"],
      "settings": {
        "foreground": "#ac79c6"
      }
    },
    {
      "name": "Functions and Methods",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "meta.method-call.java",
        "meta.instance.constructor.dart"
      ],
      "settings": {
        "foreground": "#E5C07B"
      }
    },
    {
      "name": "Class Declaration",
      "scope": [
        "entity.name.type.class",
        "entity.name.type.class.java",
        "entity.name.type.class.dart"
      ],
      "settings": {
        "foreground": "#61AFEF"
      }
    },
    {
      "name": "Types in Use",
      "scope": [
        "storage.type",
        "entity.other.inherited-class",
        "support.class",
        "storage.type.java",
        "storage.type.dart"
      ],
      "settings": {
        "foreground": "#56B6C2"
      }
    },
    {
      "name": "Variable Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#8592a8"
      }
    },
    {
      "name": "Variable Property and Field",
      "scope": ["variable.other.property", "variable.other.field"],
      "settings": {
        "foreground": "#8592a8"
      }
    },
    {
      "name": "Variable Readwrite",
      "scope": ["variable.other.readwrite"],
      "settings": {
        "foreground": "#DCDFE4"
      }
    },
    {
      "name": "Operators and Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#8592a8"
      }
    },
    {
      "name": "Annotations and Decorators",
      "scope": [
        "meta.decorator",
        "meta.annotation",
        "storage.type.annotation.java"
      ],
      "settings": {
        "foreground": "#56B6C2"
      }
    },
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag.html"],
      "settings": {
        "foreground": "#E06C75"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": ["entity.other.attribute-name.html"],
      "settings": {
        "foreground": "#61AFEF"
      }
    },
    {
      "name": "JSON Keys",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#61AFEF"
      }
    },
    {
      "name": "YAML Tags",
      "scope": ["entity.name.tag.yaml"],
      "settings": {
        "foreground": "#61AFEF"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": ["heading.markup.md", "markup.heading"],
      "settings": {
        "foreground": "#E5C07B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown List",
      "scope": ["markup.list.markdown"],
      "settings": {
        "foreground": "#ac79c6"
      }
    },
    {
      "name": "Package Keyword",
      "scope": ["keyword.other.package"],
      "settings": { "foreground": "#ca8f65" }
    },
    {
      "name": "Package Path",
      "scope": ["storage.modifier.package"],
      "settings": { "foreground": "#78afd6" }
    },
    {
      "name": "Import Keyword",
      "scope": ["keyword.other.import"],
      "settings": { "foreground": "#d2a17b" }
    },
    {
      "name": "Import Path",
      "scope": ["storage.modifier.import"],
      "settings": { "foreground": "#8fb7cf" }
    }
  ]
}
